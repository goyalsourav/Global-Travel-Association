# Template only — copy to .env and fill in real values THERE.
# The app reads .env (gitignored). This file gets committed, so never put
# real secrets in it.

# Neon Postgres connection string (Vercel dashboard -> Storage -> Neon -> DATABASE_URL)
DATABASE_URL=

# Vercel Blob read-write token (Vercel dashboard -> Storage -> Blob -> BLOB_READ_WRITE_TOKEN)
BLOB_READ_WRITE_TOKEN=

# Initial password for the /admin panel. Once the password is changed from the
# admin Settings tab it is stored (hashed) in the database and this value is
# only used as a fallback until then.
ADMIN_PASSWORD=
